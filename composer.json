{
    "name": "maksimovic/zend-soap",
    "description": "Zend Framework 1 Soap package",
    "keywords": ["framework", "zf1", "zend", "soap"],
    "homepage": "http://framework.zend.com/",
    "license": "BSD-3-Clause",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {"type": "vcs", "url": "https://github.com/maksimovic/zend-server.git"},
        {"type": "vcs", "url": "https://github.com/maksimovic/zend-uri.git"},
        {"type": "vcs", "url": "https://github.com/maksimovic/zend-xml.git"},
        {"type": "vcs", "url": "https://github.com/maksimovic/zend-loader.git"},
        {"type": "vcs", "url": "https://github.com/maksimovic/zend-validate.git"},
        {"type": "vcs", "url": "https://github.com/maksimovic/zend-registry.git"}
    ],
    "require": {
        "php": ">=8.1",
        "ext-dom": "*",
        "ext-simplexml": "*",
        "ext-soap": "*",
        "maksimovic/zend-exception": "^2.0.1",
        "zf1s/zend-server": "dev-php85-compat as 2.0.0",
        "zf1s/zend-uri": "dev-php85-compat as 2.0.0",
        "zf1s/zend-xml": "dev-php85-compat as 2.0.0",
        "zf1s/zend-loader": "dev-php85-compat as 2.0.0",
        "zf1s/zend-validate": "dev-php85-compat as 2.0.0",
        "zf1s/zend-registry": "dev-php85-compat as 2.0.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-0": {
            "Zend_Soap": "library/"
        }
    },
    "replace": {
        "zf1/zend-soap": "^1.12",
        "zf1s/zend-soap": "^1.12",
        "maksimovic/zend-server": "2.0.0",
        "maksimovic/zend-uri": "2.0.0",
        "maksimovic/zend-xml": "2.0.0",
        "maksimovic/zend-loader": "2.0.0",
        "maksimovic/zend-validate": "2.0.0",
        "maksimovic/zend-registry": "2.0.0"
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text",
        "phpstan": "phpstan analyse --memory-limit=256M"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "2.x-dev"
        }
    }
}
